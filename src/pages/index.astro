---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
---

<BaseLayout
  title="Chris Krough - Engineering Leader | Platform Architecture | AI Transformation"
  description="25 years engineering leadership. Platform architecture, M&A integration, and AI transformation. 3 IPOs, 8 acquisitions."
>
  <!-- Hero Section -->
  <Hero
    headline="Engineering Leadership & AI Transformation"
    subheadline="Platform Architecture | M&A Integration | Cloud Infrastructure"
    headlineClass="text-3xl md:text-4xl"
  />

  <!-- Positioning Statement -->
  <section class="pt-xl pb-md md:pt-2xl md:pb-lg bg-foundation">
    <div class="container-wide">
      <div class="flex justify-center mb-6">
        <div class="accent-bar"></div>
      </div>
      <p class="text-2xl md:text-3xl font-heading text-structure leading-relaxed max-w-4xl mx-auto text-center">
        25 years leading engineering organizations through IPOs, acquisitions, and platform rebuilds.
      </p>
    </div>
  </section>

  <!-- Proof Points -->
  <section class="pt-lg pb-xl md:pt-xl md:pb-2xl">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <Card variant="elevated" class="h-40 stat-card">
          <div class="flex flex-col h-full text-center">
            <div class="flex-1 flex items-center justify-center">
              <p class="text-5xl font-heading font-semibold text-accent">25+</p>
            </div>
            <p class="text-sm font-medium text-muted uppercase tracking-widest max-w-none">
              Years Experience
            </p>
          </div>
        </Card>

        <Card variant="elevated" class="h-40 stat-card">
          <div class="flex flex-col h-full text-center">
            <div class="flex-1 flex items-center justify-center">
              <p class="text-5xl font-heading font-semibold text-accent">3</p>
            </div>
            <p class="text-sm font-medium text-muted uppercase tracking-wide">
              Successful IPOs
            </p>
          </div>
        </Card>

        <Card variant="elevated" class="h-40 stat-card">
          <div class="flex flex-col h-full text-center">
            <div class="flex-1 flex items-center justify-center">
              <p class="text-5xl font-heading font-semibold text-accent">8</p>
            </div>
            <p class="text-sm font-medium text-muted uppercase tracking-widest max-w-none">
              Acquisitions
            </p>
          </div>
        </Card>

        <Card variant="elevated" class="h-40 stat-card">
          <div class="flex flex-col h-full text-center justify-between [&>p]:mb-0">
            <p class="text-lg font-heading font-semibold text-accent">Startup</p>
            <p class="text-sm text-muted">to</p>
            <p class="text-lg font-heading font-semibold text-accent">Fortune 500</p>
            <p class="text-sm font-medium text-muted uppercase tracking-widest max-w-none">
              Scale
            </p>
          </div>
        </Card>
      </div>

      <div class="mt-12 text-center">
        <p class="text-xl text-structure max-w-3xl mx-auto">
          Proven track record in rapid growth and organizational transformation.
        </p>
      </div>
    </div>
  </section>

  <!-- Current Focus -->
  <section class="section-spacing bg-foundation-deep">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-h2 font-heading font-semibold text-structure mb-8 text-center">
          Current Focus
        </h2>

        <Card variant="bordered" class="border-l-2 border-l-accent">
          <div class="space-y-4">
            <h3 class="text-h3 font-heading font-medium text-structure">
              AI Transformation Consulting
            </h3>
            <p class="text-lg text-structure leading-relaxed">
              Through <a
                href="https://backchain.ai"
                target="_blank"
                rel="noopener noreferrer"
                class="text-structure underline font-medium">Backchain</a
              >, I help organizations identify high-value AI opportunities and build
              production systems that work.
            </p>

            <div class="space-y-2">
              <p class="text-base text-muted">
                <span class="text-structure font-medium">Building:</span> Knowledge systems,
                LLM evaluation frameworks, intelligent automation
              </p>
              <p class="text-base text-muted">
                <span class="text-structure font-medium">Published:</span> Open-source agent
                skills at <a
                  href="https://github.com/backchainai/backchain-plugins"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-structure underline">backchain-plugins</a>, conforming to the
                agentskills.io specification, with an accompanying LLM evaluation framework.
              </p>
              <p class="text-base text-muted">
                <span class="text-structure font-medium">Focus:</span> Finding where AI
                actually works, not just where it's trendy
              </p>
            </div>

            <div class="pt-4">
              <a
                href="/projects"
                class="inline-block text-structure font-medium hover:text-accent-deep transition-colors"
              >
                See Projects →
              </a>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Quick Navigation -->
  <section class="section-spacing">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/experience" class="group h-full">
          <Card variant="elevated" class="h-full">
            <h3 class="text-h4 font-heading font-medium text-structure group-hover:text-accent transition-colors mb-2">
              Experience
            </h3>
            <p class="text-base text-muted">
              Backchain, Houseful/RBCx, OJO Labs, Amazon, University of Pennsylvania, and more.
            </p>
          </Card>
        </a>

        <a href="/projects" class="group h-full">
          <Card variant="elevated" class="h-full">
            <h3 class="text-h4 font-heading font-medium text-structure group-hover:text-accent transition-colors mb-2">
              Projects
            </h3>
            <p class="text-base text-muted">
              Knowledge systems, document classification, development tools, and open source
              contributions
            </p>
          </Card>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
