---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
---

<BaseLayout
  title="Experience - Chris Krough"
  description="A 25-year career across Amazon, OJO Labs, Houseful, Bazaarvoice, Rackspace, and Backchain. IPO readiness, M&A integration, and hypergrowth."
>
  <!-- Hero Section -->
  <Hero
    headline="Experience"
    subheadline="25 years engineering leadership across academia, startups, growth stage, and Fortune 500."
  />

  <!-- Timeline -->
  <section class="section-spacing">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        <ExperienceItem
          company="Backchain"
          role="Founder"
          dates="2025 - Present"
          current={true}
          outcomes={[
            'Transformation consulting for growth-stage companies: discovery, prototyping, and production implementation using advanced engineering techniques including AI',
            'Building automation, knowledge systems, document classification, and intelligent tooling',
            'Fractional engineering leadership on retainer'
          ]}
        />

        <ExperienceItem
          company="Houseful / RBCx"
          role="Director of Engineering"
          dates="2023 - 2025"
          outcomes={[
            'Led technical integration for RBCx acquisition of OJO Labs (~$200M)',
            'Migrated six cloud environments, hundreds of services, and thousands of containers across ten Kubernetes clusters with zero downtime',
            'Built Platform Engineering team from scratch, delivered 99.99%+ uptime, and met financial sector security requirements'
          ]}
        />

        <ExperienceItem
          company="OJO Labs"
          role="Advisor"
          dates="2023 - 2025"
          outcomes={[
            'Advised executive leadership and board on infrastructure and platform strategy through RBCx acquisition and subsequent Lower acquisition (May 2025)'
          ]}
        />

        <ExperienceItem
          company="OJO Labs"
          role="Technical Lead → Director of Engineering"
          dates="2019 - 2023"
          outcomes={[
            'Engineering leadership through 6,700% revenue growth and $3B in real estate transactions',
            'Integrated engineering teams through three acquisitions (WolfNet Technologies, RealSavvy, Movoto)',
            'Reduced defect-related engineering hours by 2,500+ annually',
            'Designed Kubernetes platform achieving 99.99%+ reliability and 60% hosting cost reduction'
          ]}
        />

        <ExperienceItem
          company="Amazon"
          role="Senior Systems Development Engineer"
          dates="2016 - 2019"
          outcomes={[
            'Early Kubernetes adoption and internal EKS beta testing',
            'Built orchestration platforms managing 150+ K8s clusters across 3 continents',
            'Developed AWS service operators and controllers',
            'Open source contributions: AWS Service Operator, VPN Controller, EKS tooling',
            'Represented 400 engineers in senior leadership developer experience efforts'
          ]}
        />

        <ExperienceItem
          company="Earlier Career"
          role="Various Engineering Roles"
          dates="1999 - 2016"
          outcomes={[
            'uStudio: Principal Engineer. Video platform and transcoding infrastructure.',
            'Bazaarvoice: Staff Engineer. Scaled platform through $114M IPO (2012). Integrated $168M PowerReviews acquisition. 50,000 req/sec, 30B monthly page-views.',
            'Rackspace: Systems Engineer. Scaled infrastructure through $187.5M IPO (2008). Network automation across 10 global data centers.',
            'University of Pennsylvania: Systems Programmer. Medical research systems integration, campus network infrastructure, datacenter construction.'
          ]}
        />
      </div>
    </div>
  </section>

  <!-- Additional Info -->
  <section class="section-spacing bg-foundation-deep">
    <div class="container-wide">
      <div class="max-w-2xl mx-auto text-center space-y-8">
        <div>
          <h2 class="text-h3 font-heading font-medium text-structure mb-4">
            Career Highlights
          </h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="stat-card bg-surface rounded-lg p-6">
              <p class="text-4xl font-heading font-semibold text-accent mb-2">3</p>
              <p class="text-base text-muted">IPOs Supported</p>
            </div>
            <div class="stat-card bg-surface rounded-lg p-6">
              <p class="text-4xl font-heading font-semibold text-accent mb-2">8</p>
              <p class="text-base text-muted">Acquisitions Integrated</p>
            </div>
            <div class="stat-card bg-surface rounded-lg p-6">
              <p class="text-4xl font-heading font-semibold text-accent mb-2">$3B+</p>
              <p class="text-base text-muted">Transaction Volume</p>
            </div>
            <div class="stat-card bg-surface rounded-lg p-6">
              <p class="text-4xl font-heading font-semibold text-accent mb-2">6,700%</p>
              <p class="text-base text-muted">Revenue Growth</p>
            </div>
          </div>
        </div>

        <div class="pt-8 border-t border-border">
          <p class="text-base text-muted mb-6">
            For a detailed resume or to discuss specific experience, please get in touch.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="https://www.linkedin.com/in/ckrough/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 text-structure font-medium hover:text-accent-deep transition-colors"
            >
              <svg
                class="w-5 h-5"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              LinkedIn Profile
            </a>
            <a
              href="/contact"
              class="btn-primary"
            >
              Get in Touch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
