---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });

const formatMonth = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    timeZone: 'UTC',
  });

const monthKey = (date: Date) =>
  `${date.getUTCFullYear()}-${String(date.getUTCMonth() + 1).padStart(2, '0')}`;

type Note = (typeof notes)[number];
const groups = new Map<string, { label: string; notes: Note[] }>();
for (const note of notes) {
  const key = monthKey(note.data.pubDate);
  const existing = groups.get(key);
  if (existing) {
    existing.notes.push(note);
  } else {
    groups.set(key, { label: formatMonth(note.data.pubDate), notes: [note] });
  }
}
const grouped = Array.from(groups.values());
---

<BaseLayout
  title="Notes - Chris Krough"
  description="Working observations on building agentic workflows in production: harness engineering, evaluation methods, multi-instance coordination."
>
  <Hero
    headline="Notes"
    subheadline="Working observations on building agentic workflows in production."
  />

  <section class="section-spacing">
    <div class="container-wide">
      <div class="max-w-4xl mx-auto">
        {
          notes.length === 0 ? (
            <p class="text-base text-muted">No notes yet.</p>
          ) : (
            <div class="space-y-12">
              {grouped.map((group) => (
                <section>
                  <h2 class="text-h3 font-heading font-medium text-muted mb-6 pb-2 border-b border-border">
                    {group.label}
                  </h2>
                  <ul class="space-y-8">
                    {group.notes.map((note) => (
                      <li>
                        <article>
                          <h3 class="text-h3 font-heading font-medium mb-2">
                            <a
                              href={`/notes/${note.slug}`}
                              class="text-structure hover:text-accent no-underline hover:no-underline"
                            >
                              {note.data.title}
                            </a>
                          </h3>
                          <p class="text-sm text-muted mb-3">
                            <time datetime={note.data.pubDate.toISOString()}>
                              {formatDate(note.data.pubDate)}
                            </time>
                          </p>
                          <p class="text-base text-structure leading-relaxed">
                            {note.data.description}
                          </p>
                          {note.data.tags && note.data.tags.length > 0 && (
                            <ul class="flex flex-wrap gap-2 mt-3">
                              {note.data.tags.map((tag) => (
                                <li class="text-xs text-muted border border-border rounded px-2 py-0.5">
                                  {tag}
                                </li>
                              ))}
                            </ul>
                          )}
                        </article>
                      </li>
                    ))}
                  </ul>
                </section>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
