---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<BaseLayout
  title="Notes - Chris Krough"
  description="Working observations on building agentic workflows in production: harness engineering, evaluation methods, multi-instance coordination."
>
  <Hero
    headline="Notes"
    subheadline="Working observations on building agentic workflows in production."
  />

  <section class="section-spacing">
    <div class="container-wide">
      <div class="max-w-4xl mx-auto">
        {
          notes.length === 0 ? (
            <p class="text-base text-muted">No notes yet.</p>
          ) : (
            <ul class="space-y-8">
              {notes.map((note) => (
                <li>
                  <article>
                    <h2 class="text-h3 font-heading font-medium mb-2">
                      <a
                        href={`/notes/${note.slug}`}
                        class="text-structure hover:text-accent no-underline hover:no-underline"
                      >
                        {note.data.title}
                      </a>
                    </h2>
                    <p class="text-sm text-muted mb-3">
                      <time datetime={note.data.pubDate.toISOString()}>
                        {formatDate(note.data.pubDate)}
                      </time>
                    </p>
                    <p class="text-base text-structure leading-relaxed">
                      {note.data.description}
                    </p>
                  </article>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
