---
interface Props {
  headline: string;
  subheadline?: string;
  headlineClass?: string;
  ctaText?: string;
  ctaLink?: string;
}

const { headline, subheadline, headlineClass = 'text-h1', ctaText, ctaLink } = Astro.props;

// Split subheadline by | for smart wrapping (each phrase stays together)
const subheadlineParts = subheadline?.includes('|')
  ? subheadline.split('|').map(s => s.trim())
  : null;
---

<section
  class="relative py-2xl md:py-3xl bg-gradient-to-br from-foundation-deep via-foundation to-surface/30"
>
  <div class="container-wide">
    <div class="max-w-4xl">
      <h1 class={`${headlineClass} font-heading font-semibold text-structure mb-4`}>
        {headline}
      </h1>
      <div class="accent-bar mt-4 mb-6"></div>
      {
        subheadlineParts ? (
          <p class="text-xl md:text-2xl text-muted mb-8">
            {subheadlineParts.map((part, i) => (
              <>
                <span class="whitespace-nowrap">{part}</span>
                {i < subheadlineParts.length - 1 && <span class="mx-1">|</span>}
              </>
            ))}
          </p>
        ) : subheadline && (
          <p class="text-xl md:text-2xl text-muted mb-8 max-w-2xl">
            {subheadline}
          </p>
        )
      }
      {
        ctaText && ctaLink && (
          <a href={ctaLink} class="btn-primary">
            {ctaText}
          </a>
        )
      }
    </div>
  </div>
  <!-- Bottom separator -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border/40 to-transparent"></div>
</section>
